{
    "manifest_version": 3,
    "name": "Abious Foundation",
    "version": "1.0.0",
    "description": "Access Abious Foundation rehabilitation center resources, member portal, and news updates.",
    "icons": {
        "16": "images/icon16.png",
        "48": "images/icon48.png",
        "128": "images/icon128.png"
    },
    "action": {
        "default_popup": "popup.html",
        "default_icon": {
            "16": "images/icon16.png",
            "48": "images/icon48.png",
            "128": "images/icon128.png"
        }
    },
    "background": {
        "service_worker": "background.js"
    },
    "permissions": [
        "activeTab",
        "storage",
        "tabs"
    ],
    "host_permissions": [
        "*://*.abiousfoundation.org/*",
        "*://localhost/*",
        "*://*.render.com/*"
    ],
    "web_accessible_resources": [
        {
            "resources": ["images/*"],
            "matches": ["<all_urls>"]
        }
    ],
    "browser_specific_settings": {
        "gecko": {
            "id": "abious-foundation@abious.org",
            "strict_min_version": "109.0"
        },
        "edge": {
            "browser_background_surfaces": {
                "service_worker": true
            }
        }
    }
}
